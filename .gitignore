# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/blob-report/

# frontend build outputs
/dist/

# production
/build

# misc
.DS_Store
*.pem
__pycache__/
*.pyc
*.pyo

# SBOM outputs
sbom-*.json

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo

# Rust / Tauri
/src-tauri/target/
/src-tauri/target-ra/
# Cargo.lock is committed for reproducible CI builds (Rust best practice for applications)

# secrets
.secrets/

# MCP config (local paths)
.mcp.json

# Task management (local)
.taskmaster/
.release-notes.md

# Test coverage
coverage/
coverage-rust.lcov

# Screenshots (generated by make screenshots)
docs/screenshots/

# Training data & models (large files, kept locally)
.dev/kubi-1/data/raw/
.dev/kubi-1/data/processed/
.dev/kubi-1/data/final/
.dev/kubi-1/models/*.gguf
.dev/kubi-1/training/checkpoints/
*.gguf

# Private infra docs (IPs, passwords, machine-specific setup)
.dev/kubi-1/SETUP-CONNECTION.md
.dev/kubi-1/SETUP-WINDOWS.md

# Temp files
tmp/
.tmp/
