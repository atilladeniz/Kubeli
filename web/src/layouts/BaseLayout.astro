---
import "../styles/global.css";
import pkg from "../../../package.json";

interface Props {
  title: string;
  description?: string;
  activeNav?: string;
  ogImage?: string;
  canonicalPath?: string;
  extraSchema?: Record<string, unknown>[];
}

const {
  title,
  description = "Native Kubernetes Desktop App for macOS, Windows & Linux. Multi-Cluster Management, Real-Time Monitoring, AI-Powered Log Analysis with Claude, Codex, OpenCode & Droid. Open Source & Free.",
  activeNav = "",
  ogImage = "/og-image.png",
  canonicalPath = "",
  extraSchema = []
} = Astro.props;

const currentYear = new Date().getFullYear();

// GitHub star count — resolved at BUILD time (never client-side: a per-visitor
// fetch would burn the 60-req/hr unauthenticated limit instantly). A small disk
// cache dedupes the call across all page renders in one build and across dev
// rebuilds (6h TTL), so we hit the API at most once every 6h regardless of how
// often the site rebuilds. Set GITHUB_TOKEN in CI to lift the limit to 5000/hr.
import { readFileSync, writeFileSync, mkdirSync } from "node:fs";
const ghRepo = "atilladeniz/kubeli";
const cacheFile = "node_modules/.cache/kubeli-gh-stars.json";
const ttl = 6 * 60 * 60 * 1000;
let ghStars: number | null = null;
let cached: { t: number; stars: number } | null = null;
try { cached = JSON.parse(readFileSync(cacheFile, "utf8")); } catch { /* no cache yet */ }
if (cached && Date.now() - cached.t < ttl) {
  ghStars = cached.stars;
} else {
  try {
    const res = await fetch(`https://api.github.com/repos/${ghRepo}`, {
      headers: {
        "User-Agent": "kubeli-web",
        Accept: "application/vnd.github+json",
        ...(process.env.GITHUB_TOKEN ? { Authorization: `Bearer ${process.env.GITHUB_TOKEN}` } : {}),
      },
    });
    if (res.ok) {
      ghStars = (await res.json()).stargazers_count ?? null;
      if (ghStars != null) {
        try { mkdirSync("node_modules/.cache", { recursive: true }); writeFileSync(cacheFile, JSON.stringify({ t: Date.now(), stars: ghStars })); } catch { /* read-only fs — fine */ }
      }
    }
  } catch { /* offline/rate-limited */ }
  // Fall back to a stale cached value rather than dropping the badge to "GitHub".
  if (ghStars == null && cached) ghStars = cached.stars;
}
const ghStarsLabel =
  ghStars == null
    ? null
    : ghStars >= 1000
      ? `${(ghStars / 1000).toFixed(1).replace(/\.0$/, "")}k`
      : String(ghStars);
const siteUrl = "https://kubeli.dev";
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const fullTitle = title === "Home" ? "Kubeli - Native Kubernetes Desktop App for macOS, Windows & Linux | Multi-Cluster & AI" : `${title} | Kubeli`;

// Schema.org structured data
const schemaData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Kubeli",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "macOS, Windows, Linux",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "description": description,
  "url": siteUrl,
  "author": {
    "@type": "Person",
    "name": "Atilla Deniz"
  },
  "license": "https://opensource.org/licenses/MIT",
  "softwareVersion": pkg.version,
  "downloadUrl": "https://github.com/atilladeniz/Kubeli/releases",
  "screenshot": `${siteUrl}/screens/02-cluster-overview.webp`,
  "featureList": [
    "Multi-Cluster Management",
    "Real-Time Resource Monitoring",
    "AI-Powered Log Analysis",
    "Interactive Resource Diagram",
    "Port Forwarding",
    "AI Agent Integration (Claude, Codex, OpenCode, Droid)",
    "Native Desktop App with Tauri"
  ],
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "ratingCount": "1",
    "bestRating": "5",
    "worstRating": "1"
  }
};

// WebSite schema for Google site name display
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Kubeli",
  "alternateName": "Kubeli Kubernetes Desktop App",
  "url": siteUrl
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/kubeli.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- No-FOUC theme init: set .dark before paint (stored choice, else OS). -->
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem("theme");
          var dark = s ? s === "dark" : matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.classList.toggle("dark", dark);
        } catch (e) {}
      })();
    </script>

    <!-- Inter (matches the Kubeli app). ponytail: CDN link; self-host if a 3rd-party request ever matters. -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />
    <meta name="keywords" content="kubernetes, k8s, kubernetes gui, kubernetes desktop, kubernetes management, kubernetes client, macos, tauri, rust, multi-cluster, ai, claude, openai, open source, lens alternative, k9s alternative" />
    <meta name="author" content="Atilla Deniz" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${fullTitle} - Screenshot`} />
    <meta property="og:site_name" content="Kubeli" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Additional Meta -->
    <meta name="theme-color" content="#f5f5f5" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#191a22" media="(prefers-color-scheme: dark)" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- Schema.org JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schemaData)} />
    {title === "Home" && (
      <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    )}
    {extraSchema.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- Web App Manifest -->
    <link rel="manifest" href="/manifest.json" />
  </head>
  <body class="min-h-dvh w-full m-0 flex flex-col antialiased font-sans bg-background text-foreground">
    <!-- Header -->
    <header class="border-b border-border relative z-50">
      <div class="mx-auto max-w-6xl px-4 sm:px-8 py-4 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2">
          <img src="/kubeli.svg" class="size-8" alt="Kubeli Logo" />
          <span class="font-semibold">Kubeli</span>
        </a>

        <!-- Desktop Navigation -->
        <nav class="hidden sm:flex items-center gap-6 text-sm">
          <a href="/" class={activeNav === "home" ? "text-foreground font-medium" : "text-muted-foreground hover:text-foreground transition-colors"}>Home</a>
          <a href="/screenshots" class={activeNav === "screenshots" ? "text-foreground font-medium" : "text-muted-foreground hover:text-foreground transition-colors"}>Screenshots</a>
          <a href="/changelog" class={activeNav === "changelog" ? "text-foreground font-medium" : "text-muted-foreground hover:text-foreground transition-colors"}>Changelog</a>
          <a href="https://github.com/atilladeniz/kubeli" target="_blank" rel="noopener" aria-label="Kubeli on GitHub" class="inline-flex items-center gap-1.5 rounded-md border border-border px-2.5 py-1 text-muted-foreground hover:text-foreground hover:bg-accent transition-colors">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            <span class="text-sm font-medium tabular-nums">{ghStarsLabel ?? "GitHub"}</span>
          </a>
          <button type="button" class="theme-toggle text-muted-foreground hover:text-foreground transition-colors" aria-label="Toggle theme">
            <svg class="w-5 h-5 icon-sun" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
            <svg class="w-5 h-5 icon-moon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
          </button>
        </nav>

        <!-- Mobile Menu Toggle (Vercel-style) -->
        <button
          id="mobile-menu-btn"
          class="sm:hidden relative w-6 h-6 flex items-center justify-center"
          aria-label="Open menu"
          data-expanded="false"
        >
          <div class="menu-toggle-wrapper">
            <div id="bar-top" class="menu-bar" data-position="top"></div>
            <div id="bar-bottom" class="menu-bar" data-position="bottom"></div>
          </div>
        </button>
      </div>
    </header>

    <!-- Mobile Menu Popover -->
    <div id="mobile-menu" class="mobile-menu-popover">
      <nav class="flex flex-col px-4 py-6">
        <a href="/" class={`mobile-nav-link ${activeNav === "home" ? "font-medium text-foreground" : ""}`}>Home</a>
        <a href="/screenshots" class={`mobile-nav-link ${activeNav === "screenshots" ? "font-medium text-foreground" : ""}`}>Screenshots</a>
        <a href="/changelog" class={`mobile-nav-link ${activeNav === "changelog" ? "font-medium text-foreground" : ""}`}>Changelog</a>
        <a href="https://github.com/atilladeniz/kubeli" target="_blank" rel="noopener" class="mobile-nav-link">GitHub{ghStarsLabel ? ` · ${ghStarsLabel}` : ""}</a>
        <button type="button" class="theme-toggle mobile-nav-link flex items-center gap-2" aria-label="Toggle theme">
          <svg class="w-5 h-5 icon-sun" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" /></svg>
          <svg class="w-5 h-5 icon-moon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" /></svg>
          <span>Theme</span>
        </button>
      </nav>
    </div>

    <style>
      /* Theme-toggle icons: visibility driven purely by .dark on <html> (set
         before paint by the no-FOUC script) so the right icon is correct on
         first render — no JS sync, no flash when navigating between pages. */
      .icon-moon { display: none; }
      :global(.dark) .icon-sun { display: none; }
      :global(.dark) .icon-moon { display: block; }

      /* Menu Toggle Button */
      .menu-toggle-wrapper {
        width: 18px;
        height: 12px;
        position: relative;
      }

      .menu-bar {
        position: absolute;
        left: 0;
        width: 100%;
        height: 1.5px;
        background-color: currentColor;
        transition: transform 0.3s ease, opacity 0.2s ease;
      }

      .menu-bar[data-position="top"] {
        top: 0;
      }

      .menu-bar[data-position="bottom"] {
        bottom: 0;
      }

      /* Expanded state - X */
      [data-expanded="true"] .menu-bar[data-position="top"] {
        transform: translateY(5.25px) rotate(45deg);
      }

      [data-expanded="true"] .menu-bar[data-position="bottom"] {
        transform: translateY(-5.25px) rotate(-45deg);
      }

      /* Mobile Menu Popover */
      .mobile-menu-popover {
        position: fixed;
        top: 65px;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: var(--background);
        z-index: 40;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s;
      }

      .mobile-menu-popover.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
      }

      .mobile-nav-link {
        display: block;
        width: 100%;
        text-align: left;
        padding: 16px 0;
        font-size: 1rem;
        color: var(--muted-foreground);
        border-bottom: 1px solid var(--border);
        transition: color 0.15s ease;
      }

      .mobile-nav-link:hover {
        color: var(--foreground);
      }

      /* Theme button keeps its icon inline; base rule forces display:block. */
      .mobile-nav-link.theme-toggle {
        display: flex;
        align-items: center;
        gap: 8px;
      }


      /* Hide popover on desktop */
      @media (min-width: 640px) {
        .mobile-menu-popover {
          display: none;
        }
      }
    </style>

    <script>
      const menuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');

      menuBtn?.addEventListener('click', () => {
        const isExpanded = menuBtn.getAttribute('data-expanded') === 'true';
        menuBtn.setAttribute('data-expanded', (!isExpanded).toString());
        menuBtn.setAttribute('aria-label', isExpanded ? 'Open menu' : 'Close menu');
        mobileMenu?.classList.toggle('open', !isExpanded);
        document.body.style.overflow = isExpanded ? '' : 'hidden';
      });

      // Theme toggle — flips .dark on <html> + persists. Icon visibility is pure
      // CSS keyed off .dark (set pre-paint), so no JS sync = no icon flash on nav.
      document.querySelectorAll('.theme-toggle').forEach((btn) => {
        btn.addEventListener('click', () => {
          const dark = document.documentElement.classList.toggle('dark');
          try { localStorage.setItem('theme', dark ? 'dark' : 'light'); } catch (e) {}
        });
      });
    </script>

    <main class="flex-1 flex flex-col">
      <slot />
    </main>

    <footer class="border-t border-border py-12 sm:py-16">
      <div class="mx-auto max-w-6xl px-4 sm:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
          <!-- Product -->
          <div>
            <h3 class="font-semibold text-sm text-foreground mb-4">Product</h3>
            <ul class="space-y-3 text-sm">
              <li><a href="/screenshots" class="text-muted-foreground hover:text-foreground transition-colors">Screenshots</a></li>
              <li><a href="/changelog" class="text-muted-foreground hover:text-foreground transition-colors">Changelog</a></li>
              <li><a href="https://github.com/atilladeniz/Kubeli/releases" target="_blank" rel="noopener" class="text-muted-foreground hover:text-foreground transition-colors">Downloads</a></li>
            </ul>
          </div>

          <!-- Compare -->
          <div>
            <h3 class="font-semibold text-sm text-foreground mb-4">Compare</h3>
            <ul class="space-y-3 text-sm">
              <li><a href="/compare/lens-alternative" class="text-muted-foreground hover:text-foreground transition-colors">Lens alternative</a></li>
              <li><a href="/compare/k9s-alternative" class="text-muted-foreground hover:text-foreground transition-colors">K9s alternative</a></li>
              <li><a href="/compare/dashboard-alternative" class="text-muted-foreground hover:text-foreground transition-colors">Dashboard alternative</a></li>
              <li><a href="/compare/kubectl-alternative" class="text-muted-foreground hover:text-foreground transition-colors">kubectl alternative</a></li>
            </ul>
          </div>

          <!-- Support -->
          <div>
            <h3 class="font-semibold text-sm text-foreground mb-4">Support</h3>
            <ul class="space-y-3 text-sm">
              <li><a href="https://github.com/atilladeniz/kubeli" target="_blank" rel="noopener" class="text-muted-foreground hover:text-foreground transition-colors">GitHub</a></li>
              <li><a href="https://github.com/atilladeniz/kubeli/discussions" target="_blank" rel="noopener" class="text-muted-foreground hover:text-foreground transition-colors">Discussions</a></li>
              <li><a href="https://github.com/atilladeniz/kubeli/issues/new?assignees=&labels=enhancement&template=feature_request.yml" target="_blank" rel="noopener" class="text-muted-foreground hover:text-foreground transition-colors">Feature Request</a></li>
              <li><a href="https://github.com/atilladeniz/kubeli/issues/new?assignees=&labels=bug&template=bug_report.yml" target="_blank" rel="noopener" class="text-muted-foreground hover:text-foreground transition-colors">Report a Bug</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h3 class="font-semibold text-sm text-foreground mb-4">Legal</h3>
            <ul class="space-y-3 text-sm">
              <li><a href="https://github.com/atilladeniz/kubeli/blob/main/LICENSE" target="_blank" rel="noopener" class="text-muted-foreground hover:text-foreground transition-colors">MIT License</a></li>
              <li><a href="/code-signing-policy" class="text-muted-foreground hover:text-foreground transition-colors">Code Signing Policy</a></li>
            </ul>
          </div>
        </div>

        <div class="flex items-start sm:items-center justify-center gap-2 text-xs text-muted-foreground pt-8 border-t border-border">
          <img src="/signpath-logo.svg" class="h-4 w-auto shrink-0 mt-0.5 sm:mt-0 brightness-0 opacity-60 dark:invert dark:opacity-70" alt="SignPath" />
          <span>Free code signing provided by <a href="https://about.signpath.io" target="_blank" rel="noopener" class="underline hover:text-foreground transition-colors">SignPath.io</a>, certificate by <a href="https://signpath.org" target="_blank" rel="noopener" class="underline hover:text-foreground transition-colors">SignPath Foundation</a>.</span>
        </div>

        <div class="flex flex-col sm:flex-row justify-between items-center pt-8">
          <div class="flex items-center gap-2.5 mb-4 sm:mb-0">
            <img src="/mascot/shark-sit.svg" width="32" height="32" class="w-8 h-8 shrink-0" alt="Kubeli the shark mascot" />
            <span class="text-sm text-muted-foreground">&copy; {currentYear} Kubeli. Open Source under MIT.</span>
          </div>
          <div class="flex items-center gap-4">
            <a href="https://github.com/atilladeniz/kubeli" target="_blank" rel="noopener" aria-label="Kubeli on GitHub" class="text-muted-foreground hover:text-foreground transition-colors">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
