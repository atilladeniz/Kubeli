---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
}

const { title = "Changelog" } = Astro.props;
---

<BaseLayout title={title} activeNav="changelog" description="Latest updates, new features, and improvements for Kubeli - the native Kubernetes desktop app. See what's new in each release." canonicalPath="/changelog">
  <div class="mx-auto max-w-3xl px-6 sm:px-8 py-12 sm:py-16">
    <div class="mb-12 sm:mb-16">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">Releases</p>
      <h1 class="mt-3 text-4xl sm:text-5xl font-semibold tracking-tight text-foreground">Changelog</h1>
      <p class="mt-4 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Every release of Kubeli, newest first.
      </p>
    </div>

    <article class="prose max-w-none
      prose-headings:text-foreground
      prose-h2:text-xl prose-h2:font-semibold prose-h2:tracking-tight prose-h2:mt-10 prose-h2:mb-3 first:prose-h2:mt-0
      prose-ul:my-2 prose-ul:list-disc
      prose-li:text-muted-foreground prose-li:my-0.5 prose-li:marker:text-accent-strong/60
      prose-p:text-muted-foreground prose-p:my-1
      prose-strong:text-foreground prose-strong:font-semibold
      prose-a:text-accent-strong prose-a:no-underline hover:prose-a:underline
      prose-code:text-foreground
    ">
      <slot />
    </article>
  </div>
</BaseLayout>
