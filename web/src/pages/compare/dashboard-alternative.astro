---
import BaseLayout from "../../layouts/BaseLayout.astro";
import pkg from "../../../../package.json";

const version = pkg.version;
const dmgUrl = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_aarch64.dmg`;
const appImageUrl = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_amd64.AppImage`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 3, "name": "Dashboard Alternative", "item": "https://kubeli.dev/compare/dashboard-alternative" }
  ]
};

const comparisonPoints = [
  {
    category: "Installation",
    kubeli: "Download & run",
    dashboard: "Deploy to cluster",
    winner: "kubeli",
    detail: "No cluster deployment needed. Just download and connect."
  },
  {
    category: "Security",
    kubeli: "Local app, no exposure",
    dashboard: "Requires ingress/proxy",
    winner: "kubeli",
    detail: "No need to expose a web interface to access your cluster."
  },
  {
    category: "Multi-Cluster",
    kubeli: "Yes, native",
    dashboard: "One per cluster",
    winner: "kubeli",
    detail: "Manage all clusters from one app vs. deploying Dashboard to each."
  },
  {
    category: "AI Integration",
    kubeli: "Claude, Codex, OpenCode, Droid",
    dashboard: "None",
    winner: "kubeli",
    detail: "AI-powered log analysis and troubleshooting."
  },
  {
    category: "Resource Usage",
    kubeli: "Local desktop only",
    dashboard: "Uses cluster resources",
    winner: "kubeli",
    detail: "Dashboard consumes CPU/memory in your cluster."
  },
  {
    category: "Offline Access",
    kubeli: "Works offline",
    dashboard: "Requires cluster",
    winner: "kubeli",
    detail: "View cached data even when disconnected."
  },
  {
    category: "Log Streaming",
    kubeli: "Yes + AI analysis",
    dashboard: "Basic",
    winner: "kubeli",
    detail: "Real-time logs with intelligent error detection."
  },
  {
    category: "Terminal Access",
    kubeli: "Full terminal",
    dashboard: "Basic exec",
    winner: "kubeli",
    detail: "Native terminal experience vs. web-based console."
  },
  {
    category: "Price",
    kubeli: "Free (MIT)",
    dashboard: "Free",
    winner: "tie",
    detail: "Both are free and open source."
  }
];
---

<BaseLayout
  title="Kubeli vs Kubernetes Dashboard - Desktop Alternative"
  description="Looking for a Kubernetes Dashboard alternative? Kubeli is a native desktop app for macOS, Windows & Linux that doesn't require cluster deployment. AI-powered, multi-cluster, and secure."
  activeNav=""
  canonicalPath="/compare/dashboard-alternative"
  extraSchema={[breadcrumbSchema]}
>
  <!-- ============ HERO — flush-left ============ -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
        Kubeli vs Kubernetes Dashboard
      </p>
      <h1 class="mt-5 text-5xl sm:text-6xl font-semibold tracking-tighter leading-[1.02] max-w-3xl">
        Looking for a <span class="text-accent-strong">Dashboard Alternative</span>?
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Kubeli is a native desktop app for macOS, Windows & Linux that doesn't require deploying anything to your cluster.
        Multi-cluster support, AI-powered analysis, and zero security exposure.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-strong px-6 py-3 text-base font-medium text-accent-strong-foreground hover:opacity-90 transition-opacity"
        >
          Try Kubeli Free
        </a>
      </div>
    </div>
  </section>

  <!-- ============ KEY DIFFERENCES — modular hairline grid ============ -->
  <section class="bg-muted border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">Why switch</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        Why use a desktop app instead of Dashboard?
      </h2>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 rounded-xl border border-border bg-background overflow-hidden">
        <div class="border-b border-r border-border p-8 md:border-b-0">
          <span class="font-mono text-sm text-muted-foreground">01</span>
          <h3 class="mt-5 text-lg font-semibold tracking-tight">No Cluster Exposure</h3>
          <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
            Dashboard requires ingress or port-forwarding. Kubeli connects directly via kubeconfig - no web interface to secure.
          </p>
        </div>
        <div class="border-b border-r border-border p-8 md:border-b-0">
          <span class="font-mono text-sm text-muted-foreground">02</span>
          <h3 class="mt-5 text-lg font-semibold tracking-tight">Multi-Cluster Native</h3>
          <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
            Dashboard needs to be deployed to each cluster. Kubeli manages all your clusters from one app.
          </p>
        </div>
        <div class="p-8">
          <span class="font-mono text-sm text-muted-foreground">03</span>
          <h3 class="mt-5 text-lg font-semibold tracking-tight">AI-Powered</h3>
          <p class="mt-2 text-sm text-muted-foreground leading-relaxed">
            Dashboard shows data. Kubeli analyzes it with Claude, Codex, OpenCode or Droid to help you troubleshoot.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ COMPARISON ============ -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">Comparison</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        Feature Comparison
      </h2>

      <div class="mt-12 rounded-xl border border-border bg-background overflow-hidden">
        {comparisonPoints.map((point, i) => (
          <div class={`grid grid-cols-3 gap-4 p-6 items-center ${i !== comparisonPoints.length - 1 ? 'border-b border-border' : ''}`}>
            <div>
              <div class="font-medium tracking-tight">{point.category}</div>
              <div class="text-xs text-muted-foreground mt-1 leading-relaxed">{point.detail}</div>
            </div>
            <div class={`text-center text-sm ${point.winner === 'kubeli' ? 'text-accent-strong font-semibold' : 'text-muted-foreground'}`}>
              {point.kubeli}
            </div>
            <div class="text-center text-sm text-muted-foreground">
              {point.dashboard}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA — dark closing band ============ -->
  <section class="bg-surface-inverse text-surface-inverse-foreground">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">Get started</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        Skip the cluster deployment
      </h2>
      <p class="mt-4 max-w-xl text-surface-inverse-foreground/70 leading-relaxed">
        Download Kubeli and start managing your clusters in seconds - no Helm charts, no YAML, no ingress configuration.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-strong text-accent-strong-foreground px-6 py-3 text-base font-medium hover:opacity-90 transition-opacity"
        >
          Download for macOS
        </a>
        <a
          href={appImageUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 text-surface-inverse-foreground px-6 py-3 text-base font-medium hover:bg-white/10 transition-colors"
        >
          Download for Linux
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
