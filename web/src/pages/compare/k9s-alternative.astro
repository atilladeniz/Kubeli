---
import BaseLayout from "../../layouts/BaseLayout.astro";
import pkg from "../../../../package.json";

const version = pkg.version;
const dmgUrlArm = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_aarch64.dmg`;
const appImageUrl = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_amd64.AppImage`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 3, "name": "k9s Alternative", "item": "https://kubeli.dev/compare/k9s-alternative" }
  ]
};

const comparisonPoints = [
  {
    category: "Interface",
    kubeli: "Native GUI",
    k9s: "Terminal UI (TUI)",
    winner: "kubeli",
    detail: "Visual interface with point-and-click navigation vs terminal-based."
  },
  {
    category: "Resource Visualization",
    kubeli: "Interactive diagrams",
    k9s: "Text-based lists",
    winner: "kubeli",
    detail: "See your cluster topology with visual diagrams and health indicators."
  },
  {
    category: "Log Analysis",
    kubeli: "AI-powered analysis",
    k9s: "Basic log viewer",
    winner: "kubeli",
    detail: "Claude/OpenAI integration for intelligent error analysis and suggestions."
  },
  {
    category: "Learning Curve",
    kubeli: "Intuitive GUI",
    k9s: "Keyboard shortcuts",
    winner: "kubeli",
    detail: "Point-and-click interface vs memorizing vim-style keybindings."
  },
  {
    category: "Port Forwarding",
    kubeli: "Visual management",
    k9s: "Command-based",
    winner: "kubeli",
    detail: "One-click port forwards with browser integration."
  },
  {
    category: "Performance",
    kubeli: "Fast (Rust)",
    k9s: "Fast (Go)",
    winner: "tie",
    detail: "Both are fast and lightweight."
  },
  {
    category: "Price",
    kubeli: "Free (MIT)",
    k9s: "Free (Apache 2.0)",
    winner: "tie",
    detail: "Both are open source and free."
  },
  {
    category: "Terminal Access",
    kubeli: "Integrated",
    k9s: "Native",
    winner: "tie",
    detail: "Both provide terminal access to pods."
  },
  {
    category: "IDE Integration",
    kubeli: "MCP Server",
    k9s: "None",
    winner: "kubeli",
    detail: "Query your cluster from VS Code, Cursor, or Claude Code."
  },
  {
    category: "Platforms",
    kubeli: "macOS, Windows, Linux",
    k9s: "macOS, Linux, Windows",
    winner: "tie",
    detail: "Both support all major desktop platforms."
  }
];
---

<BaseLayout
  title="Kubeli vs k9s - GUI Alternative to Terminal"
  description="Looking for a k9s alternative with a visual interface? Kubeli is a native Kubernetes GUI for macOS, Windows & Linux with AI-powered log analysis and interactive diagrams."
  activeNav=""
  canonicalPath="/compare/k9s-alternative"
  extraSchema={[breadcrumbSchema]}
>
  <!-- Hero -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">KUBELI VS K9S</p>
      <h1 class="mt-5 text-5xl sm:text-6xl font-semibold tracking-tighter leading-[1.02] max-w-3xl">
        Looking for a <span class="text-accent-strong">k9s Alternative</span>?
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Love the speed of k9s but want a visual interface? Kubeli offers the same
        performance with an intuitive GUI, interactive diagrams, and AI-powered analysis.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrlArm}
          class="inline-flex items-center gap-2 rounded-lg bg-accent-strong px-6 py-3 text-base font-medium text-accent-strong-foreground hover:opacity-90 transition-opacity"
        >
          Try Kubeli Free
        </a>
      </div>
    </div>
  </section>

  <!-- Key Differences -->
  <section class="bg-muted border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">WHY SWITCH</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        Different approaches to the same goal
      </h2>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 rounded-xl border border-border bg-background overflow-hidden">
        <div class="border-b md:border-b-0 md:border-r border-border p-8">
          <h3 class="font-semibold text-lg mb-4">k9s</h3>
          <ul class="space-y-3 text-muted-foreground">
            <li class="flex items-start gap-2">
              <span class="text-muted-foreground mt-0.5">+</span>
              <span>Fast terminal-based navigation</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted-foreground mt-0.5">+</span>
              <span>Vim-style keybindings</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted-foreground mt-0.5">+</span>
              <span>Runs in any terminal</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted-foreground mt-0.5">-</span>
              <span>Learning curve for keybindings</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-muted-foreground mt-0.5">-</span>
              <span>No visual topology view</span>
            </li>
          </ul>
        </div>
        <div class="p-8">
          <h3 class="font-semibold text-lg mb-4 flex items-center gap-2">
            Kubeli
            <span class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">GUI</span>
          </h3>
          <ul class="space-y-3 text-muted-foreground">
            <li class="flex items-start gap-2">
              <span class="text-success mt-0.5">+</span>
              <span>Point-and-click interface</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-success mt-0.5">+</span>
              <span>Interactive resource diagrams</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-success mt-0.5">+</span>
              <span>AI-powered log analysis</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-success mt-0.5">+</span>
              <span>Native desktop experience (macOS, Windows & Linux)</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">COMPARISON</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        Feature Comparison
      </h2>

      <div class="mt-12 rounded-xl border border-border bg-background overflow-hidden divide-y divide-border">
        {comparisonPoints.map((point) => (
          <div class="grid grid-cols-3 gap-4 p-6 items-center">
            <div>
              <div class="font-medium">{point.category}</div>
              <div class="text-xs text-muted-foreground mt-1">{point.detail}</div>
            </div>
            <div class={point.winner === 'kubeli' ? 'font-medium text-accent-strong' : 'text-muted-foreground'}>
              {point.kubeli}
            </div>
            <div class={point.winner === 'k9s' ? 'font-medium text-accent-strong' : 'text-muted-foreground'}>
              {point.k9s}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- When to use which -->
  <section class="bg-surface-inverse text-surface-inverse-foreground border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">PICK YOUR TOOL</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        When to use which?
      </h2>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 rounded-xl border border-white/10 overflow-hidden">
        <div class="border-b md:border-b-0 md:border-r border-white/10 p-8 md:p-10">
          <h3 class="font-semibold text-lg mb-4">Choose k9s if you:</h3>
          <ul class="space-y-2 text-surface-inverse-foreground/70">
            <li>Love terminal-based workflows</li>
            <li>Already know vim keybindings</li>
            <li>Prefer SSH-based workflows</li>
            <li>Work primarily over SSH</li>
          </ul>
        </div>
        <div class="p-8 md:p-10">
          <h3 class="font-semibold text-lg mb-4">Choose Kubeli if you:</h3>
          <ul class="space-y-2 text-surface-inverse-foreground/70">
            <li>Prefer visual interfaces</li>
            <li>Want AI-assisted troubleshooting</li>
            <li>Need to visualize cluster topology</li>
            <li>Use macOS, Windows, or Linux as your primary OS</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">GET STARTED</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">Ready to try the visual approach?</h2>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Download Kubeli for free and see if a GUI fits your workflow.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrlArm}
          class="inline-flex items-center gap-2 rounded-lg bg-accent-strong px-6 py-3 text-base font-medium text-accent-strong-foreground hover:opacity-90 transition-opacity"
        >
          Download for macOS
        </a>
        <a
          href={appImageUrl}
          class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 text-base font-medium text-foreground hover:bg-accent transition-colors"
        >
          Download for Linux
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
