---
import BaseLayout from "../../layouts/BaseLayout.astro";
import pkg from "../../../../package.json";

const version = pkg.version;
const dmgUrl = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_aarch64.dmg`;
const appImageUrl = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_amd64.AppImage`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 3, "name": "kubectl Alternative", "item": "https://kubeli.dev/compare/kubectl-alternative" }
  ]
};

const comparisonPoints = [
  {
    category: "Interface",
    kubeli: "Visual GUI",
    kubectl: "Command line",
    winner: "kubeli",
    detail: "Point-and-click vs. memorizing commands and flags."
  },
  {
    category: "Learning Curve",
    kubeli: "Intuitive",
    kubectl: "Steep",
    winner: "kubeli",
    detail: "No need to remember kubectl get, describe, logs syntax."
  },
  {
    category: "Resource Overview",
    kubeli: "Visual diagrams",
    kubectl: "Text output",
    winner: "kubeli",
    detail: "See your cluster topology at a glance."
  },
  {
    category: "Log Analysis",
    kubeli: "AI-powered",
    kubectl: "Raw text",
    winner: "kubeli",
    detail: "Claude/OpenAI helps identify errors and suggest fixes."
  },
  {
    category: "Multi-Cluster",
    kubeli: "Switch with click",
    kubectl: "Context switching",
    winner: "kubeli",
    detail: "No more kubectl config use-context."
  },
  {
    category: "Port Forwarding",
    kubeli: "Visual management",
    kubectl: "Manual commands",
    winner: "kubeli",
    detail: "One-click port forwards with browser integration."
  },
  {
    category: "Terminal Access",
    kubeli: "Built-in",
    kubectl: "Native",
    winner: "tie",
    detail: "Both provide shell access to pods."
  },
  {
    category: "Scripting",
    kubeli: "GUI focused",
    kubectl: "Full scripting",
    winner: "kubectl",
    detail: "kubectl is better for automation and scripts."
  },
  {
    category: "Price",
    kubeli: "Free (MIT)",
    kubectl: "Free",
    winner: "tie",
    detail: "Both are free and open source."
  }
];
---

<BaseLayout
  title="Kubeli vs kubectl - Visual Alternative to CLI"
  description="Looking for a kubectl alternative with a visual interface? Kubeli is a native Kubernetes GUI for macOS, Windows & Linux with AI-powered analysis. No commands to memorize."
  activeNav=""
  canonicalPath="/compare/kubectl-alternative"
  extraSchema={[breadcrumbSchema]}
>
  <!-- Hero -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">
        Kubeli vs kubectl
      </p>
      <h1 class="mt-5 text-5xl sm:text-6xl font-semibold tracking-tighter leading-[1.02] max-w-3xl">
        Looking for a <span class="text-accent-strong">kubectl Alternative</span>?
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Love Kubernetes but tired of memorizing commands? Kubeli gives you a visual interface
        with all the power of kubectl - plus AI-powered analysis.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-strong px-6 py-3 text-base font-medium text-accent-strong-foreground hover:opacity-90 transition-opacity"
        >
          Try Kubeli Free
        </a>
      </div>
    </div>
  </section>

  <!-- Key Differences -->
  <section class="bg-muted border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">Why switch</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        kubectl commands → Kubeli clicks
      </h2>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Common kubectl workflows become simple visual actions.
      </p>
      <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="font-mono text-sm text-muted-foreground mb-2">kubectl</div>
          <code class="text-sm bg-muted px-2 py-1 rounded">kubectl get pods -n default</code>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border border-2">
          <div class="font-mono text-sm text-accent-strong mb-2">Kubeli</div>
          <span class="text-sm">Click namespace → See all pods</span>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="font-mono text-sm text-muted-foreground mb-2">kubectl</div>
          <code class="text-sm bg-muted px-2 py-1 rounded">kubectl logs -f pod-name</code>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border border-2">
          <div class="font-mono text-sm text-accent-strong mb-2">Kubeli</div>
          <span class="text-sm">Click pod → Live logs + AI analysis</span>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="font-mono text-sm text-muted-foreground mb-2">kubectl</div>
          <code class="text-sm bg-muted px-2 py-1 rounded">kubectl port-forward svc/name 8080:80</code>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border border-2">
          <div class="font-mono text-sm text-accent-strong mb-2">Kubeli</div>
          <span class="text-sm">Click service → One-click forward</span>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border">
          <div class="font-mono text-sm text-muted-foreground mb-2">kubectl</div>
          <code class="text-sm bg-muted px-2 py-1 rounded">kubectl config use-context prod</code>
        </div>
        <div class="bg-card p-6 rounded-xl border border-border border-2">
          <div class="font-mono text-sm text-accent-strong mb-2">Kubeli</div>
          <span class="text-sm">Click cluster in sidebar</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">Comparison</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">
        Feature Comparison
      </h2>

      <div class="mt-12 space-y-4">
        {comparisonPoints.map((point) => (
          <div class="bg-card border border-border rounded-xl overflow-hidden">
            <div class="grid grid-cols-3 gap-4 p-4 items-center">
              <div>
                <div class="font-medium">{point.category}</div>
                <div class="text-xs text-muted-foreground mt-1">{point.detail}</div>
              </div>
              <div class={`text-center py-2 rounded-lg ${point.winner === 'kubeli' ? 'border border-border bg-card text-accent-strong font-medium' : ''}`}>
                {point.kubeli}
              </div>
              <div class={`text-center py-2 rounded-lg ${point.winner === 'kubectl' ? 'border border-border bg-card text-foreground font-medium' : 'text-muted-foreground'}`}>
                {point.kubectl}
              </div>
            </div>
          </div>
        ))}
      </div>

      <p class="text-muted-foreground text-sm mt-8">
        Note: Kubeli complements kubectl - you can still use CLI when needed.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-surface-inverse text-surface-inverse-foreground border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">Get started</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">Ready to see your clusters visually?</h2>
      <p class="mt-5 max-w-2xl text-lg text-surface-inverse-foreground/70 leading-relaxed">
        Download Kubeli and experience Kubernetes management without memorizing commands.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-strong text-accent-strong-foreground px-6 py-3 text-base font-medium hover:opacity-90 transition-opacity"
        >
          Download for macOS
        </a>
        <a
          href={appImageUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-white/20 text-surface-inverse-foreground px-6 py-3 text-base font-medium hover:bg-white/10 transition-colors"
        >
          Download for Linux
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
