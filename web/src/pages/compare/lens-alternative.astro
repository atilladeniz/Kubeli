---
import BaseLayout from "../../layouts/BaseLayout.astro";
import pkg from "../../../../package.json";

const version = pkg.version;
const dmgUrlArm = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_aarch64.dmg`;
const appImageUrl = `https://github.com/atilladeniz/Kubeli/releases/download/v${version}/Kubeli_${version}_amd64.AppImage`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 2, "name": "Compare", "item": "https://kubeli.dev/" },
    { "@type": "ListItem", "position": 3, "name": "Lens Alternative", "item": "https://kubeli.dev/compare/lens-alternative" }
  ]
};

const comparisonPoints = [
  {
    category: "Architecture",
    kubeli: "Tauri 2.0 + Rust",
    lens: "Electron",
    winner: "kubeli",
    detail: "Kubeli uses native system webview instead of bundling Chromium, resulting in 70x smaller app size."
  },
  {
    category: "App Size",
    kubeli: "26.8MB",
    lens: "~1.93 GB",
    winner: "kubeli",
    detail: "Lens bundles a full Chromium browser. Kubeli uses the native OS WebView."
  },
  {
    category: "Memory Usage",
    kubeli: "~100 MB",
    lens: "~350+ MB",
    winner: "kubeli",
    detail: "Native architecture means significantly lower RAM consumption."
  },
  {
    category: "Startup Time",
    kubeli: "<1 second",
    lens: "~6 seconds",
    winner: "kubeli",
    detail: "Rust backend and native webview enable instant startup."
  },
  {
    category: "AI Integration",
    kubeli: "Claude, Codex, OpenCode, Droid",
    lens: "Lens Prism only",
    winner: "kubeli",
    detail: "Kubeli lets you choose your preferred AI agent."
  },
  {
    category: "MCP Server",
    kubeli: "Included",
    lens: "Not available",
    winner: "kubeli",
    detail: "Unique: Query your cluster from VS Code, Cursor, or Claude Code."
  },
  {
    category: "Price",
    kubeli: "Free forever (MIT)",
    lens: "Free limited / $25-50/mo",
    winner: "kubeli",
    detail: "Kubeli is 100% open source with no paid tiers."
  },
  {
    category: "Multi-Cluster",
    kubeli: "Yes",
    lens: "Yes",
    winner: "tie",
    detail: "Both support connecting to multiple clusters."
  },
  {
    category: "Terminal",
    kubeli: "Yes",
    lens: "Yes",
    winner: "tie",
    detail: "Both provide integrated terminal access to pods."
  },
  {
    category: "Helm Support",
    kubeli: "Yes",
    lens: "Yes",
    winner: "tie",
    detail: "Both support Helm chart management."
  }
];
---

<BaseLayout
  title="Kubeli vs Lens - The Lightweight Alternative"
  description="Looking for a Lens alternative? Kubeli is a native Kubernetes client for macOS, Windows & Linux that's 70x smaller, uses 3x less memory, and is 100% free. Compare features."
  activeNav=""
  canonicalPath="/compare/lens-alternative"
  extraSchema={[breadcrumbSchema]}
>
  <!-- Hero -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-muted-foreground">KUBELI VS LENS</p>
      <h1 class="mt-5 text-5xl sm:text-6xl font-semibold tracking-tighter leading-[1.02] max-w-3xl">
        Looking for a <span class="text-accent-strong">Lens Alternative</span>?
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Kubeli is a native Kubernetes client for macOS, Windows & Linux that's 70x smaller, uses 3x less memory,
        starts instantly, and is 100% free and open source.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrlArm}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-strong px-6 py-3 text-base font-medium text-accent-strong-foreground hover:opacity-90 transition-opacity"
        >
          Try Kubeli Free
        </a>
      </div>
    </div>
  </section>

  <!-- Key Differences -->
  <section class="bg-muted border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-14 sm:py-16">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-px bg-border overflow-hidden rounded-xl border border-border">
        <div class="bg-muted p-8">
          <div class="text-5xl sm:text-6xl font-semibold tracking-tighter text-accent-strong">70x</div>
          <div class="mt-3 font-medium text-foreground">Smaller App Size</div>
          <div class="mt-1 font-mono text-xs text-muted-foreground">26.8MB vs 1.9GB</div>
        </div>
        <div class="bg-muted p-8">
          <div class="text-5xl sm:text-6xl font-semibold tracking-tighter text-accent-strong">3x</div>
          <div class="mt-3 font-medium text-foreground">Less Memory</div>
          <div class="mt-1 font-mono text-xs text-muted-foreground">100MB vs 350MB</div>
        </div>
        <div class="bg-muted p-8">
          <div class="text-5xl sm:text-6xl font-semibold tracking-tighter text-accent-strong">6x</div>
          <div class="mt-3 font-medium text-foreground">Faster Startup</div>
          <div class="mt-1 font-mono text-xs text-muted-foreground">&lt;1s vs 6s</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">COMPARISON</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl mb-10">
        Feature-by-Feature Comparison
      </h2>

      <div class="space-y-4">
        {comparisonPoints.map((point) => (
          <div class="bg-card border border-border rounded-xl overflow-hidden">
            <div class="grid grid-cols-3 gap-4 p-4 items-center">
              <div>
                <div class="font-medium">{point.category}</div>
                <div class="text-xs text-muted-foreground mt-1">{point.detail}</div>
              </div>
              <div class={`text-center py-2 ${point.winner === 'kubeli' ? 'font-semibold text-accent-strong' : 'text-muted-foreground'}`}>
                {point.kubeli}
              </div>
              <div class="text-center py-2 text-muted-foreground">
                {point.lens}
              </div>
            </div>
          </div>
        ))}
      </div>

      <div class="flex gap-8 mt-8 text-sm text-muted-foreground">
        <div class="flex items-center gap-2">
          <div class="w-3 h-3 rounded bg-accent-strong"></div>
          <span>Kubeli advantage</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Switch -->
  <section class="bg-surface-inverse text-surface-inverse-foreground border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">WHY SWITCH</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl mb-12">
        Why developers are switching from Lens
      </h2>

      <div class="space-y-8 max-w-2xl">
        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-success/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">No more Electron bloat</h3>
            <p class="text-surface-inverse-foreground/70 mt-1">
              Lens bundles an entire Chromium browser. Kubeli uses native OS WebView for a lightweight experience.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-success/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Truly free, no feature gating</h3>
            <p class="text-surface-inverse-foreground/70 mt-1">
              Lens Pro costs $25/month. Kubeli is MIT licensed - all features free, forever. No login required.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-success/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">AI integration you control</h3>
            <p class="text-surface-inverse-foreground/70 mt-1">
              Choose between Claude, Codex, OpenCode or Droid for AI analysis. Your data stays local - no cloud processing.
            </p>
          </div>
        </div>

        <div class="flex gap-4">
          <div class="flex-shrink-0 w-8 h-8 rounded-full bg-success/20 flex items-center justify-center">
            <svg class="w-4 h-4 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <div>
            <h3 class="font-semibold text-lg">Native desktop experience</h3>
            <p class="text-surface-inverse-foreground/70 mt-1">
              Vibrancy effects, system-level integration, and a fraction of the memory footprint.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section>
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-16 sm:py-24">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">GET STARTED</p>
      <h2 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight max-w-2xl">Ready to try the lighter alternative?</h2>
      <p class="mt-5 max-w-2xl text-lg text-muted-foreground leading-relaxed">
        Download Kubeli for free and experience the difference.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a
          href={dmgUrlArm}
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent-strong px-6 py-3 text-base font-medium text-accent-strong-foreground hover:opacity-90 transition-opacity"
        >
          Download for macOS
        </a>
        <a
          href={appImageUrl}
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-border px-6 py-3 text-base font-medium text-foreground hover:bg-accent transition-colors"
        >
          Download for Linux
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
