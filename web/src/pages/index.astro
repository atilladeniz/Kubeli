  <section class="border-b border-border">
    <div class="mx-auto max-w-6xl px-6 sm:px-8 py-20 sm:py-28">
      <p class="font-mono text-xs uppercase tracking-[0.2em] text-accent-strong">Product tour</p>
      <h2 class="mt-3 max-w-2xl text-3xl sm:text-4xl font-semibold tracking-tight">
