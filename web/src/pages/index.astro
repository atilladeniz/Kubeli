      </h2>

      <div id="tour" class="mt-12">
        <!-- Tab cells (each: title + desc), hairline-divided, active = progress bar -->
        <div class="flex divide-x divide-border border-y border-border overflow-x-auto hide-scrollbar md:overflow-x-visible" role="tablist" aria-label="Product tour">
          {tour.map((t, i) => (
            <button
              type="button"
              class="tour-tab group relative w-[230px] shrink-0 md:w-auto md:min-w-0 md:flex-1 px-6 py-5 text-left transition-colors hover:bg-accent/60 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:-outline-offset-2"
              role="tab"
              aria-controls={`tour-panel-${i}`}
              data-tab={i}
              data-active={i === 0 ? "true" : "false"}
            >
              <span class="flex items-baseline gap-2">
                <span class="font-mono text-xs text-muted-foreground/50">{String(i + 1).padStart(2, "0")}</span>
                <span class="tour-tab-title text-[15px] font-medium text-muted-foreground transition-colors">{t.name}</span>
              </span>
              <span class="mt-1.5 block text-sm leading-snug text-muted-foreground">{t.desc}</span>
              <span class="tour-bar pointer-events-none absolute -bottom-px left-0 right-0 h-[2px] origin-left bg-accent-strong"></span>
            </button>
          ))}
        </div>

        <!-- Stage: all panels stacked absolutely in a fixed-aspect box and cross-faded
             via opacity (Medusa pattern). No display toggle = no reflow, no flicker;
             every image stays painted so switching is a pure opacity transition. -->
        <div class="mt-6 rounded-2xl border border-border bg-muted p-2 sm:p-4 lg:p-5">
          <div class="relative mx-auto aspect-[1600/989] w-full max-w-5xl">
            {tour.map((t, i) => (
              <div
                id={`tour-panel-${i}`}
                class="tour-panel absolute inset-0"
                role="tabpanel"
                data-panel={i}
                data-active={i === 0 ? "true" : "false"}
              >
                <img
                  src={t.src}
                  srcset={t.srcset}
                  sizes="(max-width: 1024px) 96vw, 1100px"
                  width={1600}
                  height={989}
                  alt={t.alt}
                  class="block h-full w-full rounded-xl bg-muted object-cover"
                  loading={i === 0 ? "eager" : "lazy"}
                />
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <style>
      .hide-scrollbar { scrollbar-width: none; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }

      .tour-tab[data-active="true"] .tour-tab-title { color: var(--foreground); }

      /* Progress bar: hidden until its tab is active, then grows 0 -> 100%. */
      .tour-bar { transform: scaleX(0); }
      .tour-tab[data-active="true"] .tour-bar {
        animation: tour-grow var(--tour-dur, 6s) linear forwards;
      }
      @keyframes tour-grow { from { transform: scaleX(0); } to { transform: scaleX(1); } }

      /* Cross-fade: panels are stacked; only opacity changes. Inactive panels stay
         in the DOM (painted) so there's no repaint flash when one becomes active. */
      .tour-panel { opacity: 0; pointer-events: none; transition: opacity 0.3s ease; }
      .tour-panel[data-active="true"] { opacity: 1; pointer-events: auto; }

      @media (prefers-reduced-motion: reduce) {
        .tour-tab[data-active="true"] .tour-bar { animation: none; transform: scaleX(1); }
        .tour-panel { transition: none; }
      }
    </style>

    <script>
      const root = document.getElementById("tour");
      if (root) {
        const tabs = Array.from(root.querySelectorAll<HTMLElement>(".tour-tab"));
        const panels = Array.from(root.querySelectorAll<HTMLElement>(".tour-panel"));
        const DUR = 6000;
        const reduce = matchMedia("(prefers-reduced-motion: reduce)").matches;
        let idx = 0;
        let timer: ReturnType<typeof setInterval> | undefined;

        const show = (i: number) => {
          idx = i;
          tabs.forEach((t, j) => t.setAttribute("data-active", String(j === i)));
          panels.forEach((p, j) => p.setAttribute("data-active", String(j === i)));
        };
        const start = () => {
          if (reduce) return;
          clearInterval(timer);
          timer = setInterval(() => show((idx + 1) % tabs.length), DUR);
        };

        tabs.forEach((tab, i) => tab.addEventListener("click", () => { show(i); start(); }));
        // Pause the carousel while the user is hovering the stage.
        root.addEventListener("mouseenter", () => clearInterval(timer));
        root.addEventListener("mouseleave", start);

        show(0);
        start();
      }
    </script>
  </section>

